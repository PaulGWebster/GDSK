	  __try
	    {
	      long __l;
#ifndef _GLIBCXX_LONG_DOUBLE_ALT128_COMPAT
	      const __num_get_type& __ng = __check_facet(this->_M_num_get);
#else
	      const __num_get_type& __ng
		= use_facet<__num_get_type>(this->_M_ios_locale);
#endif
