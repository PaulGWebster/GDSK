		this->_M_invalidate_if(_Equal(__x));
		__to_destroy.splice(__to_destroy.begin(), *this, __x);
#if !_GLIBCXX_USE_CXX11_ABI
		_GLIBCXX20_ONLY( __removed++ );
#endif
	      }

	    __x = __next;
	  }

#if !_GLIBCXX_USE_CXX11_ABI
	  return _GLIBCXX20_ONLY( __removed );
#else
