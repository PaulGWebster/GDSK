		{
		  this->_M_invalidate_if([__x](_Base_const_iterator __it)
					 { return __it == __x; });
		  __to_destroy.splice_after(__to_destroy.cbefore_begin(),
					    *this, __old);
		  __x = __old;
		  _GLIBCXX20_ONLY( __removed++ );
