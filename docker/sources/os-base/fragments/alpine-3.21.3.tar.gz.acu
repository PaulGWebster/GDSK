	  return _Base::remove(__val);

	size_type __removed __attribute__((__unused__)) = 0;
	_Base __to_destroy(get_allocator());
	_Base_const_iterator __x = _Base::cbefore_begin();
	_Base_const_iterator __old = __x++;
