	  while (++__next != __last)
	    if (__binary_pred(*__first, *__next))
	      {
		this->_M_invalidate_if(_Equal(__next));
		__to_destroy.splice(__to_destroy.begin(), *this, __next);
		__next = __first;
#if !_GLIBCXX_USE_CXX11_ABI
		_GLIBCXX20_ONLY( __removed++ );
#endif
