		_Base_const_iterator __next = std::next(__old);
		this->_M_invalidate_if([__next](_Base_const_iterator __it)
				       { return __it == __next; });
		__to_destroy.splice_after(__to_destroy.cbefore_begin(),
					  *this, __old);
