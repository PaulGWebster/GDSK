_OutputIterator __brick_set_union(_RandomAccessIterator1, _RandomAccessIterator1, _RandomAccessIterator2,
                                  _RandomAccessIterator2, _OutputIterator, _Compare,
                                  /*__is_vector=*/std::true_type) noexcept;

